{
  "version": 2,
  "builds": [
    {
      "src": "web-app/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "web-app/server.js"
    },
    {
      "src": "/(.*\\.(js|css|html|json|png|svg))",
      "dest": "web-app/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "web-app/public/home.html"
    }
  ]
}